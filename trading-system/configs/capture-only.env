# Capture-only profile: ingest + persist market data, place NO orders.
#
# Use this to accumulate order-book / candle history for weeks (e.g. building
# the order-book-imbalance dataset) without any paper or testnet trading.
#
#   cp configs/capture-only.env .env   # then fill DATABASE_URL / dashboard secrets
#   RUST_LOG=trading_api=info cargo run -p trading-api --bin trading-api
#
# Why this is no-trade (verified against crates/api/src/main.rs):
#   - MARKET_DATA_ENABLED=true  -> WS streams subscribe + every event persists.
#   - PAPER_TRADING_ENABLED=false -> the paper strategy loop is not spawned.
#   - TRADING_MODE=paper (NOT testnet) -> the testnet order-placing loop (the only
#     path that calls place_market_order) is not spawned.
#   - BINANCE_TESTNET_ENABLED=false -> no testnet keys are required or used.
# With both trading loops off, market events flow only to the DB.
#
# NOTE: order_books is append-only (no pruning) and ingests tens of thousands of
# rows/min across 3 exchanges x 2 symbols — budget disk / add a retention step
# before a multi-week run.

API_HOST=127.0.0.1
API_PORT=8080
DASHBOARD_CONTROL_TOKEN=
DASHBOARD_PASSWORD=
DASHBOARD_SESSION_SECRET=
DATABASE_URL=postgres://postgres:postgres@127.0.0.1:5432/trading_system
DATABASE_MAX_CONNECTIONS=5
RUN_MIGRATIONS=true
MARKET_DATA_ENABLED=true
MARKET_DATA_EXCHANGES=binance,bybit,bitget
MARKET_DATA_SYMBOLS=BTCUSDT,ETHUSDT
# Persist at most one order-book row per (exchange, symbol) per second. Keeps the
# 1s resolution the imbalance hypothesis needs while cutting disk ~50-100x so a
# multi-month capture fits. 0 = every event (default elsewhere).
MARKET_DATA_ORDERBOOK_SAMPLE_SECS=1
PAPER_TRADING_ENABLED=false
PAPER_EQUITY=10000
PAPER_DAILY_LOSS_LIMIT=500
PAPER_MAX_CANDLES_PER_KEY=100
AI_FILTER_ENABLED=false
AI_FILTER_FAIL_CLOSED=true
AI_MACRO_SCORE=0
AI_LONG_BIAS=0
AI_SHORT_BIAS=0
AI_PATTERN_CONFIDENCE=70
AI_HISTORICAL_WIN_RATE=70
BINANCE_TESTNET_ENABLED=false
BINANCE_TESTNET_API_KEY=
BINANCE_TESTNET_API_SECRET=
BINANCE_TESTNET_MAX_ORDER_NOTIONAL=50
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_CHAT_ID=
TELEGRAM_NOTIFY_CHAT_ID=
TRADING_MODE=paper
LIVE_TRADING_APPROVED=false
RUST_LOG=trading_api=info
